# Copy to `.env.local` to use. Forge runs fully in mock mode with NONE of these
# set — provide them only to go beyond the deterministic simulator.

# Enables the Claude model adapter (see src/lib/engineering-agent/mock-model.ts).
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Enables Postgres persistence via the Supabase adapter
# (see src/lib/store/supabase-adapter.ts and supabase/schema.sql).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
